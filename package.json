{
  "name": "trade-agent-new",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch src/index.ts",
    "dev:web": "vite",
    "dev": "concurrently -n server,web -c green,cyan \"npm run dev:server\" \"npm run dev:web\"",
    "build:server": "tsc -p tsconfig.json && node -e \"import('node:fs').then(fs=>{fs.cpSync('src/db/migrations','dist/db/migrations',{recursive:true})})\"",
    "build:web": "vite build",
    "build": "npm run build:server && npm run build:web",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "croner": "^8.1.2",
    "fastify": "^5.0.0",
    "pg": "^8.13.1",
    "typebox": "^1.1.24",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cronstrue": "^2.51.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
